# Copy to .env and fill in. .env is gitignored. Placeholders are fine until we wire
# real services (Sections 8.3, 8.6, 8.7).

# --- Database: Supabase Postgres ---
# Use the "Shared Pooler" (transaction mode) URI from the Supabase Connect panel.
# `prepare: false` is already set in core/src/db/client.ts for pooler compatibility.
DATABASE_URL=postgresql://postgres.PLACEHOLDER:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Optional: connection used only by drizzle-kit migrations. Prefer the Supabase
# "Session pooler" / direct connection (port 5432). Falls back to DATABASE_URL if unset.
DIRECT_URL=

# --- API (local dev only; Vercel injects its own) ---
PORT=3001

# --- Google Form configs (production) ---
# Local dev reads core/forms.local.json. On Vercel that file is NOT deployed (gitignored),
# so set FORMS_CONFIG_JSON to the compact JSON of core/forms.local.json (run: npm run forms:print).
FORMS_CONFIG_JSON=

# --- Firebase Admin (push sender) — Section 8.6 ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Web push (VAPID) — Section 8.6 ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Firebase web/PWA client config (EXPO_PUBLIC_* are exposed to the client; non-secret) ---
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_VAPID_KEY=
# Files (gitignored, not in .env): app/google-services.json (Android) and
# firebase-service-account.json (the FIREBASE_* values above come from it).

# --- Email fallback (Gmail SMTP) — Section 8.6 ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=youraddress@gmail.com
SMTP_PASS=
EMAIL_FROM=youraddress@gmail.com

# --- Dispatch (Section 8.7) ---
# Base URL of the web app (used for the email confirm link). e.g. https://your-app.vercel.app
WEB_URL=
# Protects /api/internal/dispatch; Vercel Cron sends it as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=
