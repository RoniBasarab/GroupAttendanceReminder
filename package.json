{
  "name": "group-attendance-reminder",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "core",
    "app",
    "api",
    "worker"
  ],
  "scripts": {
    "app": "npm run start -w @gar/app",
    "dev:api": "npm run dev -w @gar/api",
    "dev:worker": "npm run dev -w @gar/worker",
    "worker:tick": "npm run tick -w @gar/worker",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.4.2",
    "typescript": "~6.0.3"
  }
}
